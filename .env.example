# =============================================================================
# Auth Bootstrap Package – Environment Variables
# Copy this file to .env and fill in the values.
# =============================================================================

# ─── Server ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string for Prisma
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/pmis?schema=public"

# ─── JWT – User Auth ──────────────────────────────────────────────────────────
# Secret used to sign access tokens for regular users
AUTH_JWT_SECRET=change_me_user_jwt_secret_at_least_32_chars

# Secret used to sign refresh tokens for regular users (should differ from access)
AUTH_REFRESH_JWT_SECRET=change_me_user_refresh_secret_at_least_32_chars

# ─── JWT – Employee Auth ──────────────────────────────────────────────────────
# Secret used to sign access tokens for employees / admin staff
EMPLOYEE_AUTH_JWT_SECRET=change_me_employee_jwt_secret_at_least_32_chars

# Secret used to sign refresh tokens for employees
EMPLOYEE_AUTH_REFRESH_JWT_SECRET=change_me_employee_refresh_secret_at_least_32_chars

# ─── JWT Shared Settings ──────────────────────────────────────────────────────
JWT_ISSUER=auth-bootstrap
JWT_AUDIENCE=auth-bootstrap-users

# Access token lifetime (e.g. 15m, 1h, 7d)
ACCESS_TOKEN_EXPIRES_IN=15m

# Refresh token lifetime in days
REFRESH_TOKEN_EXPIRES_IN_DAYS=7

# ─── OTP ─────────────────────────────────────────────────────────────────────
# How long (in minutes) an OTP remains valid
OTP_EXPIRES_IN_MINUTES=5

# How many OTP attempts are allowed before a lockout
OTP_MAX_ATTEMPTS=5

# ─── Rate Limiting ────────────────────────────────────────────────────────────
# Max login/OTP requests per window (per IP or identifier)
RATE_LIMIT_MAX_ATTEMPTS=5

# Rate limit window in minutes
RATE_LIMIT_WINDOW_MINUTES=15

# ─── SMS Provider ─────────────────────────────────────────────────────────────
# The SmsService is a stub – wire up your own provider (Twilio, Infobip, etc.)
# SMS_API_URL=https://your-sms-provider.com/api/send
# SMS_API_KEY=your_sms_api_key
# SMS_SENDER_ID=YourApp
